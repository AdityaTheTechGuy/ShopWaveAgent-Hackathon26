%%{init: {'theme': 'base'}}%%
flowchart TB
    User([User]) --> CLI[CLI main.py]
    CLI --> Guard{"Input <= 600 chars?"}
    Guard -- No --> ShortMsg[Ask user to shorten request]
    Guard -- Yes --> Router[LLM Router in agent.py]

    Router --> Intent{"Detected intent"}

    Intent -- Policy --> PolicyTool[search_knowledge_base]
    Intent -- Cancel or Refund --> Precheck{"Order ID present?"}
    Intent -- Product or Catalog --> ProductTool[get_product_info or list_available_products]
    Intent -- Buy --> PlaceOrderTool[place_order]
    Intent -- Angry or escalation --> EscalateTool[escalate_to_human]
    Intent -- Other support --> ToolDecision{"Tool call needed?"}

    Precheck -- No --> AskOrderID[Ask for order ID]
    Precheck -- Yes --> OrderTools[cancel_order or refund sequence]

    ToolDecision -- No --> DirectReply[Compose direct reply]
    ToolDecision -- Yes --> ToolNode[tool_node parallel execution]

    PolicyTool --> DirectReply
    AskOrderID --> DirectReply
    EscalateTool --> DirectReply

    OrderTools --> ToolNode
    ProductTool --> ToolNode
    PlaceOrderTool --> ToolNode

    ToolNode --> Rules[tools.py validation rules]
    Rules --> Persist[(Persist orders and customers JSON)]
    Persist --> FinalReply[Final AI reply]
    DirectReply --> FinalReply

    ShortMsg --> Render[Render response in Rich panel]
    FinalReply --> Render
    Render --> Audit[Async audit log write]

    classDef guard fill:#fff7ed,stroke:#f59e0b,color:#7c2d12,stroke-width:1px;
    classDef action fill:#eef2ff,stroke:#6366f1,color:#1e1b4b,stroke-width:1px;
    classDef data fill:#ecfdf5,stroke:#10b981,color:#064e3b,stroke-width:1px;
    classDef warn fill:#fef2f2,stroke:#ef4444,color:#7f1d1d,stroke-width:1px;

    class Guard,Intent,Precheck,ToolDecision guard;
    class CLI,Router,PolicyTool,OrderTools,ProductTool,PlaceOrderTool,EscalateTool,ToolNode,Rules,FinalReply,DirectReply,Render,Audit,AskOrderID action;
    class Persist data;
    class ShortMsg warn;
